/** app.wxss 全局样式 **/

/* 颜色变量 */
page {
  --primary: #7785AC;
  --secondary1: #360568;
  --secondary2: #5b2a86;
  --secondary3: #9ac6c5;
  --secondary4: #a5e6ba;
  --bg: #f5f5f5;
  --white: #ffffff;
  --text: #333333;
  --text-light: #666666;
  --text-lighter: #999999;
  --border: #e8e8e8;
  --shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);

  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Helvetica Neue', Arial, sans-serif;
  font-size: 28rpx;
  color: var(--text);
  background-color: var(--bg);
  box-sizing: border-box;
}

/* 通用容器 */
.container {
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

/* 主色按钮 */
.btn-primary {
  background-color: var(--primary);
  color: #ffffff;
  border: none;
  border-radius: 16rpx;
  font-size: 30rpx;
  font-weight: 500;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 22rpx 48rpx;
  transition: all 0.2s ease;
}

.btn-primary:active {
  opacity: 0.8;
  transform: scale(0.97);
}

/* 加载动画 */
@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

@keyframes fadeOut {
  from { opacity: 1; }
  to { opacity: 0; }
}

@keyframes slideUp {
  from { transform: translateY(40rpx); opacity: 0; }
  to { transform: translateY(0); opacity: 1; }
}

@keyframes spin {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

@keyframes pulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.5; }
}
